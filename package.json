{
  "name": "qa-interview-automation",
  "version": "1.0.0",
  "description": "Playwright UI + API automation — interview assessment",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test src/tests/ui.spec.ts",
    "test:api": "npx playwright test src/tests/api.spec.ts",
    "test:headed": "npx playwright test --headed",
    "report": "npx playwright show-report",
    "install:browsers": "npx playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "typescript": "^5.4.5"
  }
}
